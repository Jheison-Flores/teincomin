---

<section id="proyectos" class="py-24 bg-white border-b border-zinc-200 scroll-mt-20">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Cabecera de la Sección -->
    <div class="max-w-3xl mb-16 space-y-2">
      <span class="block text-xs font-bold tracking-wider text-orange-600 uppercase">PORTAFOLIO DE OBRAS</span>
      <h2 class="text-2xl sm:text-3xl font-extrabold text-zinc-900 tracking-tight">
        Proyectos Nacionales e Internacionales Ejecutados
      </h2>
    </div>

    <!-- Cuadrícula de 12 Tarjetas de Proyecto -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {projects.map((project) => (
        <div class="space-y-4 flex flex-col justify-between border border-zinc-200 p-4 rounded-sm bg-zinc-50/30 shadow-2xs hover:shadow-md transition-all">
          <div class="space-y-3">
            <!-- Imagen con Recorte Asimétrico Superior Estilo Poderosa -->
            <div class="w-full h-40 bg-zinc-100 rounded-tr-[40px] overflow-hidden border border-zinc-200/60">
              <img 
                src={project.image} 
                alt={project.title} 
                class="w-full h-full object-cover object-center transition-transform duration-500 hover:scale-105"
              />
            </div>

            <!-- Título Principal -->
            <h3 class="text-base font-extrabold text-zinc-900 leading-snug uppercase min-h-0.5 flex items-center">
              {project.title}
            </h3>

            <!-- Ubicación -->
            <span class="block text-[11px] font-bold text-orange-600 tracking-wide uppercase">
              📍 {project.location}
            </span>

            <!-- Descripción básica -->
            <p class="text-xs text-zinc-600 leading-relaxed font-normal line-clamp-3">
              {project.description}
            </p>
          </div>

          <!-- Botón de Ficha Técnica que abre el Modal -->
          <div class="pt-2">
            <button 
              data-project-id={project.id}
              class="open-modal-btn w-full inline-flex items-center justify-between bg-zinc-800 hover:bg-zinc-900 text-white rounded-xs overflow-hidden group transition-all"
            >
              <span class="px-3 py-2 text-xs font-bold tracking-wide">
                LEER MÁS
              </span>
              <span class="bg-orange-500 p-2.5 flex items-center justify-center group-hover:bg-orange-600 transition-colors">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
                </svg>
              </span>
            </button>
          </div>
        </div>
      ))}
    </div>

  </div>

  <!-- ==================== MODAL DINÁMICO (VENTANA EMERGENTE) ==================== -->
  <!-- Línea Corregida: Quitamos 'flex' de aquí para que 'hidden' funcione por defecto -->
<div id="project-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
    <!-- Fondo translúcido oscuro -->
    <div id="modal-overlay" class="absolute inset-0 bg-zinc-950/70 backdrop-blur-xs"></div>
    
    <!-- Contenedor del Modal -->
    <div class="relative bg-white border border-zinc-200 w-full max-w-2xl rounded-sm shadow-2xl z-10 overflow-hidden flex flex-col md:flex-row">
      
      <!-- Imagen Izquierda en el modal -->
      <div class="w-full md:w-1/2 h-48 md:h-auto bg-zinc-100">
        <img id="modal-image" src="" alt="" class="w-full h-full object-cover" />
      </div>

      <!-- Datos a la Derecha -->
      <div class="w-full md:w-1/2 p-6 flex flex-col justify-between space-y-6">
        <div class="space-y-3">
          <span id="modal-location" class="text-xs font-bold text-orange-600 uppercase tracking-wider"></span>
          <h3 id="modal-title" class="text-xl font-black text-zinc-900 uppercase tracking-tight"></h3>
          <hr class="border-zinc-200" />
          <h4 class="text-xs font-bold text-zinc-400 uppercase tracking-wide">Especificaciones Técnicas:</h4>
          <p id="modal-details" class="text-xs text-zinc-600 leading-relaxed font-normal"></p>
        </div>

        <!-- Botón de Cerrar Modal -->
        <button id="close-modal-btn" class="w-full bg-zinc-100 hover:bg-zinc-200 text-zinc-800 text-xs font-bold py-2.5 rounded-xs transition-colors border border-zinc-200">
          CERRAR FICHA
        </button>
      </div>

    </div>
  </div>
</section>

<!-- ==================== LÓGICA DE CONTROL DEL MODAL ==================== -->
<script define:vars={{ projects }}>
  const modal = document.getElementById('project-modal');
  const overlay = document.getElementById('modal-overlay');
  const closeModalBtn = document.getElementById('close-modal-btn');
  
  const mTitle = document.getElementById('modal-title');
  const mLocation = document.getElementById('modal-location');
  const mDetails = document.getElementById('modal-details');
  const mImage = document.getElementById('modal-image');

  // Abre el modal cargando los datos correspondientes
  document.querySelectorAll('.open-modal-btn').forEach(button => {
    button.addEventListener('click', () => {
      const pId = button.getAttribute('data-project-id');
      const data = projects.find(p => p.id === pId);
      
      if (data) {
            mTitle.textContent = data.title;
            mLocation.textContent = `📍 ${data.location}`;
            mDetails.textContent = data.details;
            mImage.src = data.image;
            mImage.alt = data.title;
            
            // CORRECCIÓN AQUÍ: Quitamos hidden y activamos flex
            modal.classList.remove('hidden');
            modal.classList.add('flex'); 
            document.body.style.overflow = 'hidden';
        }
    });
  });

  // Funciones para cerrar el modal
  const closeModal = () => {
  // CORRECCIÓN AQUÍ: Quitamos flex y regresamos a hidden
    modal.classList.remove('flex');
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    };

  closeModalBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', closeModal);
</script>