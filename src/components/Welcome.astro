---

<section id="nosotros" class="py-8 bg-gray-200 border-b border-zinc-200 scroll-mt-20">
  <!-- Contenedor principal que une las pestañas y el contenido -->
<div class="max-w-7xl mx-auto py-12 px-6">
  
  <!-- Tus Pestañas (Se mantienen igual) -->
  <div class="flex flex-wrap gap-4 border-b border-zinc-200 mb-8" id="tab-container">
    {tabs.map((tab, index) => (
      <button 
        class={`pb-4 font-bold text-sm uppercase tracking-wider transition-colors ${index === 0 ? 'text-orange-600 border-b-2 border-orange-600' : 'text-zinc-400 hover:text-orange-600'}`}
        data-target={tab.id}
      >
        {tab.label}
      </button>
    ))}
  </div>
  <!-- Contenido Dinámico con Teo a un costado -->
  {tabs.map((tab, index) => (
  <div id={tab.id} class={`tab-content ${index === 0 ? '' : 'hidden'}`}>
    
    <!-- Cambiamos el orden: Imagen primero, luego Texto -->
    <div class="flex flex-col md:flex-row items-center gap-8">
      
      <!-- Imagen de Teo (Ahora a la izquierda) -->
      <div class="w-48 shrink-0">
        <img 
          src="/public/Images/Teo/inf1.png" 
          alt="Teo" 
          class="w-full h-auto object-contain"
        />
      </div>

      <!-- Bloque de Texto (Ahora a la derecha) -->
      <div class="flex-1">
        <h2 class="text-2xl font-extrabold text-zinc-900 mb-6">{tab.label}</h2>
        <p class="text-zinc-600 leading-relaxed whitespace-pre-line">{tab.content}</p>
      </div>

    </div>
  </div>
))}
</div>
</section>

<script>
  const container = document.querySelector('#tab-container');
  
  if (container) {
    container.addEventListener('click', (e) => {
      // Usamos 'as' o una verificación de tipo para que TS no se queje
      const target = e.target as HTMLElement;
      const button = target.closest('button');
      
      if (!button) return;

      const targetId = button.getAttribute('data-target');
      
      // 1. Limpiar botones (estilos)
      container.querySelectorAll('button').forEach(btn => {
        btn.classList.remove('text-orange-600', 'border-b-2', 'border-orange-600');
        btn.classList.add('text-zinc-400');
      });
      
      // 2. Activar botón clickeado
      button.classList.add('text-orange-600', 'border-b-2', 'border-orange-600');
      button.classList.remove('text-zinc-400');

      // 3. Ocultar todos los contenidos
      document.querySelectorAll('.tab-content').forEach(content => {
        content.classList.add('hidden');
      });

      // 4. Mostrar el objetivo
      if (targetId) {
        const targetElement = document.getElementById(targetId);
        if (targetElement) {
          targetElement.classList.remove('hidden');
        }
      }
    });
  }
</script>